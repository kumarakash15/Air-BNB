<%layout("/layout/bollerplate")%>

    <body>
        <main class="container mt-5">
            <!-- Listing Title and Image -->
            <section class="row justify-content-center">
                <div class="col-lg-10">
                    <h1 class="mb-4">
                        <%= listing.title %>
                    </h1>
                </div>
                <div class="col-lg-10">
                    <div class="card shadow-sm">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.image.filename %>"
                            style="height: 400px; object-fit: cover;">
                        <div class="card-body">
                            <!-- Listing Details -->
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><strong>Owner:</strong>
                                    <%= listing.owner.username %>
                                </li>
                                <li class="list-group-item"><strong>Description:</strong>
                                    <%= listing.description %>
                                </li>
                                <li class="list-group-item"><strong>Price:</strong> &#8377;<%=
                                        listing.price.toLocaleString("en-IN") %> /night</li>
                                <li class="list-group-item"><strong>Location:</strong>
                                    <%= listing.location %>
                                </li>
                                <li class="list-group-item"><strong>Country:</strong>
                                    <%= listing.country %>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Edit/Delete Buttons for Listing Owner -->
            <% if(CurrentUser && CurrentUser._id.equals(listing.owner._id)) { %>
                <section class="row justify-content-center mt-4">
                    <div class="col-lg-10 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
                            Edit Listing
                        </a>

                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                            <button class="btn btn-danger">
                                Delete Listing
                            </button>
                        </form>
                    </div>
                </section>
            <% } %>
                    <!-- Review Section -->
                    <section id="reviews" class="row justify-content-center mt-5">
                        <div class="col-lg-10">
                            <!-- Leave a Review Form -->
                            <% if(CurrentUser) { %>
                                <hr>
                                <h3 class="mb-3">Leave a Review</h3>
                                <div class="card">
                                    <div class="card-body">
                                        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate
                                            class="needs-validation">
                                            <div class="mb-3">
                                                <label for="rating" class="form-label">Rating:</label>
                                                <fieldset class="starability-slot">
                                                    <input type="radio" id="no-rate" class="input-no-rate"
                                                        name="review[rating]" value="1" checked
                                                        aria-label="No rating." />
                                                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                                                    <label for="rate1" title="Terrible">1 star</label>
                                                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                                                    <label for="rate2" title="Not good">2 stars</label>
                                                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                                                    <label for="rate3" title="Average">3 stars</label>
                                                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                                                    <label for="rate4" title="Very good">4 stars</label>
                                                    <input type="radio" id="rate5" name="review[rating]" value="5" />
                                                    <label for="rate5" title="Amazing">5 stars</label>
                                                </fieldset>
                                            </div>
                                            <div class="mb-3">
                                                <label for="comment" class="form-label">Comment:</label>
                                                <textarea name="review[comment]" id="comment" cols="30" rows="4"
                                                    class="form-control" required></textarea>
                                                <div class="valid-feedback">Looks good!</div>
                                                <div class="invalid-feedback">Please enter a comment.</div>
                                            </div>
                                            <button class="btn btn-success">Submit Review</button>
                                        </form>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Display All Reviews -->
                                    <% if(listing.reviews.length> 0) { %>
                                        <hr>
                                        <h3 class="mb-4">All Reviews</h3>
                                        <div class="row">
                                            <% for(let review of listing.reviews) { %>
                                                <div class="col-md-6 col-lg-4 mb-4">
                                                    <article class="card h-100 shadow-sm">
                                                        <div class="card-body d-flex flex-column">
                                                            <h5 class="card-title">
                                                                <%= review.author.username %>
                                                            </h5>
                                                            <p class="card-text starability-result"
                                                                data-rating="<%= review.rating %>">
                                                                Rated: <%= review.rating %> stars
                                                            </p>
                                                            <p class="card-text flex-grow-1">
                                                                <%= review.comment %>
                                                            </p>
                                                        </div>
                                                        <!-- SECURITY: Only show delete button to review author or listing owner -->
                                                        <% if(CurrentUser && (CurrentUser._id.equals(review.author._id)
                                                            || CurrentUser._id.equals(listing.owner._id))) { %>
                                                            <div class="card-footer bg-transparent border-top-0">
                                                                <form
                                                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                                    method="POST">
                                                                    <button
                                                                        class="btn btn-sm btn-outline-danger">Delete</button>
                                                                </form>
                                                            </div>
                                                            <% } %>
                                                    </article>
                                                </div>
                                                <% } %>
                                        </div>
                                        <% } %>
                        </div>
                    </section>

                    <!-- Map Section -->
                    <section class="row justify-content-center mt-5 mb-5">
                        <div class="col-lg-10">
                            <hr>
                            <h3 class="mb-3">Location on Map</h3>
                            <div id="map" class="shadow rounded" style="height: 400px;"></div>
                        </div>
                    </section>
        </main>

        <script>
            const listingLocation = "<%= listing.location %>";
        </script>
    </body>